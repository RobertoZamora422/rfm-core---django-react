# Desarrollo local
DJANGO_SECRET_KEY=change-me-only-for-local-development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=
FRONTEND_PUBLIC_URL=http://localhost:5173
DATABASE_URL=

# Seguridad y conexiones
AUTH_TOKEN_TTL_HOURS=24
THROTTLE_AUTH_LOGIN=10/minute
THROTTLE_PUBLIC_PRECOTIZACION=60/hour
THROTTLE_PUBLIC_PREFERENCIA=120/hour
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=1048576
DATABASE_CONN_MAX_AGE=60
DATABASE_DISABLE_SERVER_SIDE_CURSORS=True
DJANGO_LOG_LEVEL=INFO

# Produccion Koyeb + Neon (valores ilustrativos, nunca copie secretos al repositorio)
# DJANGO_SECRET_KEY=<secret-long-and-random>
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=<service>.koyeb.app
# CORS_ALLOWED_ORIGINS=https://<project>.pages.dev,https://<custom-domain>
# CSRF_TRUSTED_ORIGINS=https://<project>.pages.dev,https://<custom-domain>,https://<service>.koyeb.app
# FRONTEND_PUBLIC_URL=https://<project>.pages.dev
# DATABASE_URL=postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<database>?sslmode=require&channel_binding=require
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_PRELOAD=True
# DJANGO_SUPERUSER_USERNAME=<initial-admin>
# DJANGO_SUPERUSER_EMAIL=<admin-email>
# DJANGO_SUPERUSER_PASSWORD=<one-time-secret>
